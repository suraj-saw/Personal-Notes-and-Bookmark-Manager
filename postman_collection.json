{
  "info": {
    "name": "Notes & Bookmark Manager API",
    "description": "Complete API collection for testing the Notes & Bookmark Manager",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Register User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"testuser\",\n  \"email\": \"test@example.com\",\n  \"password\": \"test123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/register",
              "host": ["{{base_url}}"],
              "path": ["auth", "register"]
            }
          }
        },
        {
          "name": "Login User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test@example.com\",\n  \"password\": \"test123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/login",
              "host": ["{{base_url}}"],
              "path": ["auth", "login"]
            }
          }
        },
        {
          "name": "Get Current User",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/auth/me",
              "host": ["{{base_url}}"],
              "path": ["auth", "me"]
            }
          }
        }
      ]
    },
    {
      "name": "Notes",
      "item": [
        {
          "name": "Get All Notes",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/notes",
              "host": ["{{base_url}}"],
              "path": ["notes"]
            }
          }
        },
        {
          "name": "Search Notes",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/notes?q=search&tags=work,personal",
              "host": ["{{base_url}}"],
              "path": ["notes"],
              "query": [
                {
                  "key": "q",
                  "value": "search"
                },
                {
                  "key": "tags",
                  "value": "work,personal"
                }
              ]
            }
          }
        },
        {
          "name": "Get Single Note",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/notes/:id",
              "host": ["{{base_url}}"],
              "path": ["notes", ":id"],
              "variable": [
                {
                  "key": "id",
                  "value": "NOTE_ID_HERE"
                }
              ]
            }
          }
        },
        {
          "name": "Create Note",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"My First Note\",\n  \"content\": \"This is the content of my note\",\n  \"tags\": [\"work\", \"important\"],\n  \"isFavorite\": false\n}"
            },
            "url": {
              "raw": "{{base_url}}/notes",
              "host": ["{{base_url}}"],
              "path": ["notes"]
            }
          }
        },
        {
          "name": "Update Note",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Updated Note Title\",\n  \"content\": \"Updated content\",\n  \"tags\": [\"work\"],\n  \"isFavorite\": true\n}"
            },
            "url": {
              "raw": "{{base_url}}/notes/:id",
              "host": ["{{base_url}}"],
              "path": ["notes", ":id"],
              "variable": [
                {
                  "key": "id",
                  "value": "NOTE_ID_HERE"
                }
              ]
            }
          }
        },
        {
          "name": "Delete Note",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/notes/:id",
              "host": ["{{base_url}}"],
              "path": ["notes", ":id"],
              "variable": [
                {
                  "key": "id",
                  "value": "NOTE_ID_HERE"
                }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Bookmarks",
      "item": [
        {
          "name": "Get All Bookmarks",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/bookmarks",
              "host": ["{{base_url}}"],
              "path": ["bookmarks"]
            }
          }
        },
        {
          "name": "Search Bookmarks",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/bookmarks?q=search&tags=articles,tools",
              "host": ["{{base_url}}"],
              "path": ["bookmarks"],
              "query": [
                {
                  "key": "q",
                  "value": "search"
                },
                {
                  "key": "tags",
                  "value": "articles,tools"
                }
              ]
            }
          }
        },
        {
          "name": "Get Single Bookmark",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/bookmarks/:id",
              "host": ["{{base_url}}"],
              "path": ["bookmarks", ":id"],
              "variable": [
                {
                  "key": "id",
                  "value": "BOOKMARK_ID_HERE"
                }
              ]
            }
          }
        },
        {
          "name": "Create Bookmark",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"url\": \"https://example.com\",\n  \"title\": \"Example Website\",\n  \"description\": \"A useful example website\",\n  \"tags\": [\"resources\", \"tools\"],\n  \"isFavorite\": false\n}"
            },
            "url": {
              "raw": "{{base_url}}/bookmarks",
              "host": ["{{base_url}}"],
              "path": ["bookmarks"]
            }
          }
        },
        {
          "name": "Create Bookmark (Auto-fetch Title)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"url\": \"https://github.com\",\n  \"tags\": [\"dev\", \"tools\"]\n}"
            },
            "url": {
              "raw": "{{base_url}}/bookmarks",
              "host": ["{{base_url}}"],
              "path": ["bookmarks"]
            }
          }
        },
        {
          "name": "Update Bookmark",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"url\": \"https://example.com\",\n  \"title\": \"Updated Title\",\n  \"description\": \"Updated description\",\n  \"tags\": [\"resources\"],\n  \"isFavorite\": true\n}"
            },
            "url": {
              "raw": "{{base_url}}/bookmarks/:id",
              "host": ["{{base_url}}"],
              "path": ["bookmarks", ":id"],
              "variable": [
                {
                  "key": "id",
                  "value": "BOOKMARK_ID_HERE"
                }
              ]
            }
          }
        },
        {
          "name": "Delete Bookmark",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/bookmarks/:id",
              "host": ["{{base_url}}"],
              "path": ["bookmarks", ":id"],
              "variable": [
                {
                  "key": "id",
                  "value": "BOOKMARK_ID_HERE"
                }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/health",
          "host": ["{{base_url}}"],
          "path": ["health"]
        }
      }
    }
  ],
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:5000/api",
      "type": "string"
    },
    {
      "key": "token",
      "value": "YOUR_JWT_TOKEN_HERE",
      "type": "string"
    }
  ]
}
